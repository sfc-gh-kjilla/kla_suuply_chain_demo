# Snowflake Cortex Agent Configuration
# Copy this to .env.local and fill in your values

# Your Snowflake account URL (e.g., https://your-account.snowflakecomputing.com)
VITE_SNOWFLAKE_ACCOUNT_URL=

# Personal Access Token (PAT) for authentication
# Generate at: Snowsight > Profile > Personal Access Tokens
VITE_SNOWFLAKE_PAT=
